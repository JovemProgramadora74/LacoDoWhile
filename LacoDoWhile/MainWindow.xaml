<Window x:Class="LacoDoWhile.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LacoDoWhile"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Width="400" VerticalAlignment="Center">
            <TextBlock FontSize="20" Text="Digite um número de 0 à 10:" />
            <TextBox FontSize="16" x:Name="tbNumeroEscolhido" KeyDown="QuandoEnterPressionado" />
            <Button Content="Começar o sorteio" Margin="0 16 0 0" Click="ComecarSortear" x:Name="btnComecarSortear" />
        </StackPanel>
    </Grid>
</Window>